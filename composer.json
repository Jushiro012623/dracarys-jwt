{
    "name": "dracarys/jwt",
    "description": "A Lightweight PHP JSON Web Token Library",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Dracarys\\Jwt\\": "src/",
            "Dracarys\\Test\\": "tests/"
        }
    },
    "homepage": "https://github.com/jushiro012623/dracarys-jwt",
    "keywords": ["jwt", "jws", "hmac", "jwt.io", "json-web-token"],
    "support": {
        "issues": "https://github.com/jushiro012623/dracarys-jwt/issues",
        "source": "https://github.com/jushiro012623/dracarys-jwt"
    },
    "authors": [
        {
            "name": "Ivan Macabontoc",
            "email": "ivanallen64@gmail.com"
        }
    ],
    "require": {
      "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.4"
    },
    "scripts": {
        "setup": [
            "composer install",
            "php -r \"if (!file_exists('tests/keys/private.pem')) { mkdir('tests/keys', 0777, true); exec('openssl genpkey -algorithm RSA -out tests/keys/private.pem -pkeyopt rsa_keygen_bits:2048'); exec('openssl rsa -pubout -in tests/keys/private.pem -out tests/keys/public.pem'); }\""
        ],
        "dev": "composer install --dev",
        "lint": "phpcs --standard=PSR2 src/",
        "fix": "phpcbf --standard=PSR2 src/",
        "test-coverage": "phpunit --coverage-html=coverage",
        "test": "phpunit"
    }
}

